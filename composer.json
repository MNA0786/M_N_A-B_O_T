{
    "name": "entertainment-tadka/telegram-bot",
    "description": "Entertainment Tadka Telegram Movie Bot",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-zip": "*",
        "ext-mbstring": "*"
    },
    "autoload": {
        "files": [
            "index.php"
        ]
    },
    "scripts": {
        "post-install-cmd": [
            "@php -r \"chmod('movies.csv', 0666);\" || true",
            "@php -r \"chmod('users.json', 0666);\" || true",
            "@php -r \"chmod('bot_stats.json', 0666);\" || true",
            "@php -r \"chmod('movie_requests.json', 0666);\" || true",
            "@php -r \"chmod('user_settings.json', 0666);\" || true",
            "@php -r \"chmod('delete_queue.json', 0666);\" || true",
            "@php -r \"chmod('filter_sessions.json', 0666);\" || true",
            "@php -r \"chmod('bot_activity.log', 0666);\" || true",
            "@php -r \"mkdir('backups', 0777);\" || true",
            "@php -r \"chmod('backups', 0777);\" || true"
        ]
    },
    "config": {
        "platform-check": false,
        "optimize-autoloader": true,
        "allow-plugins": {
            "php-http/discovery": false
        }
    }
}
